{
  "buildCommand": "echo 'using pre-built dist'",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/", "destination": "/analysis", "permanent": false }
  ],
  "rewrites": [
    { "source": "/analysis", "destination": "/index.html" },
    { "source": "/analysis/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/claude.js": {
      "maxDuration": 30
    }
  }
}
